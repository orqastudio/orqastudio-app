#!/usr/bin/env bash
# Orqa Studio pre-commit hook
# Runs all quality checks before allowing a commit.
# Install: git config core.hooksPath .githooks

set -euo pipefail

echo "=== Pre-commit: Running quality checks ==="

# Rust checks (only if Rust files changed)
RUST_CHANGED=$(git diff --cached --name-only --diff-filter=ACMR -- '*.rs' 'Cargo.toml' 'Cargo.lock' | head -1)
if [ -n "$RUST_CHANGED" ]; then
  echo "--- Rust: format-check ---"
  make format-check
  echo "--- Rust: lint-backend ---"
  make lint-backend
  echo "--- Rust: test ---"
  make test-rust
fi

# Frontend checks (only if frontend files changed)
FRONTEND_CHANGED=$(git diff --cached --name-only --diff-filter=ACMR -- '*.svelte' '*.ts' '*.js' '*.css' '*.html' | head -1)
if [ -n "$FRONTEND_CHANGED" ]; then
  echo "--- Frontend: svelte-check + TypeScript ---"
  make typecheck
  echo "--- Frontend: lint-frontend ---"
  make lint-frontend
  echo "--- Frontend: test ---"
  make test-frontend
fi

# Collect rule-overrides from staged tasks/epics (used by schema validation)
RULE_OVERRIDES_JSON=$(node .githooks/collect-rule-overrides.mjs 2>/dev/null || echo "{}")
WARN_RULES=""
if [ "$RULE_OVERRIDES_JSON" != "{}" ]; then
  # Extract rule IDs from the JSON keys
  WARN_RULES=$(node -e "const o=JSON.parse(process.argv[1]);console.log(Object.keys(o).join(','))" "$RULE_OVERRIDES_JSON" 2>/dev/null || true)
  if [ -n "$WARN_RULES" ]; then
    echo "--- Rule overrides active: $WARN_RULES ---"
  fi
fi

# Artifact auto-linking and schema validation (only if .orqa/ markdown files changed)
ORQA_CHANGED=$(git diff --cached --name-only --diff-filter=ACMR -- '.orqa/**/*.md' | grep -v 'README\.md' || true)
if [ -n "$ORQA_CHANGED" ]; then
  echo "--- Artifacts: auto-link bare IDs ---"
  node .githooks/autolink-artifacts.mjs $ORQA_CHANGED
  echo "--- Artifacts: schema validation ---"
  if [ -n "$WARN_RULES" ]; then
    bash .githooks/validate-artifacts.sh --warn-rules="$WARN_RULES" $ORQA_CHANGED
  else
    bash .githooks/validate-artifacts.sh $ORQA_CHANGED
  fi
  echo "--- Artifacts: link verification ---"
  node tools/verify-links.mjs --staged --check-bidirectional
  echo "--- Artifacts: pipeline integrity ---"
  node tools/verify-pipeline-integrity.mjs --staged
fi

# Stub scanner (only if production code files changed)
PROD_CODE_CHANGED=$(git diff --cached --name-only --diff-filter=ACMR -- '*.rs' '*.ts' '*.svelte' '*.js' | head -1)
if [ -n "$PROD_CODE_CHANGED" ]; then
  echo "--- Code: stub scanner ---"
  bash .githooks/scan-stubs.sh
fi

# Task dependency gate (only if task files changed)
TASKS_CHANGED=$(git diff --cached --name-only --diff-filter=ACMR -- '.orqa/planning/tasks/TASK-*.md' | head -1)
if [ -n "$TASKS_CHANGED" ]; then
  echo "--- Artifacts: task dependency gate ---"
  bash .githooks/validate-task-deps.sh
fi

# Epic readiness gate (only if epic files changed)
EPICS_CHANGED=$(git diff --cached --name-only --diff-filter=ACMR -- '.orqa/planning/epics/EPIC-*.md' | head -1)
if [ -n "$EPICS_CHANGED" ]; then
  echo "--- Artifacts: epic readiness gate ---"
  bash .githooks/validate-epic-readiness.sh
fi

# Core graph artifact protection (skip for dogfood projects)
DOGFOOD=$(node -e "try{const p=JSON.parse(require('fs').readFileSync('.orqa/project.json','utf8'));console.log(p.dogfood?'true':'false')}catch{console.log('false')}" 2>/dev/null || echo "false")
if [ "$DOGFOOD" != "true" ] && [ "${ORQA_CORE_OVERRIDE:-}" != "1" ]; then
  CORE_PATHS=(
    ".orqa/planning/pillars/schema.json"
    ".orqa/planning/milestones/schema.json"
    ".orqa/planning/epics/schema.json"
    ".orqa/planning/tasks/schema.json"
    ".orqa/planning/ideas/schema.json"
    ".orqa/planning/research/schema.json"
    ".orqa/governance/lessons/schema.json"
    ".orqa/governance/decisions/schema.json"
    ".orqa/governance/rules/schema.json"
    ".orqa/team/agents/schema.json"
    ".orqa/team/skills/schema.json"
    ".orqa/team/agents/orchestrator.md"
    ".orqa/team/skills/composability/SKILL.md"
    ".orqa/team/skills/research-methodology/SKILL.md"
    ".orqa/team/skills/planning/SKILL.md"
    ".orqa/team/skills/orqa-code-search/SKILL.md"
  )
  CORE_MODIFIED=""
  for core_path in "${CORE_PATHS[@]}"; do
    if git diff --cached --name-only | grep -qF "$core_path"; then
      CORE_MODIFIED="$CORE_MODIFIED  $core_path"$'\n'
    fi
  done
  if [ -n "$CORE_MODIFIED" ]; then
    echo ""
    echo "WARNING: CORE GRAPH ARTIFACTS MODIFIED"
    echo ""
    echo "The following files define OrqaStudio's thinking structure:"
    echo "$CORE_MODIFIED"
    echo "Changing these risks breaking graph traversal and context injection."
    echo "Core artifacts are updated through OrqaStudio releases."
    echo ""
    echo "To proceed: ORQA_CORE_OVERRIDE=1 git commit ..."
    exit 1
  fi
fi

# If nothing relevant changed, still confirm
if [ -z "$RUST_CHANGED" ] && [ -z "$FRONTEND_CHANGED" ] && [ -z "$ORQA_CHANGED" ] && [ -z "$PROD_CODE_CHANGED" ] && [ -z "$TASKS_CHANGED" ] && [ -z "$EPICS_CHANGED" ]; then
  echo "No Rust, frontend, artifact, or planning files changed — skipping quality checks."
fi

echo "=== Pre-commit: All checks passed ==="
