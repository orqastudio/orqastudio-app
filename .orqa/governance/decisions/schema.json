{
  "$id": "orqa://schemas/decision",
  "title": "Decision",
  "description": "Architecture decision record",
  "type": "object",
  "required": ["id", "title", "description", "status", "created", "updated"],
  "additionalProperties": false,
  "propertyOrder": [
    "id", "title", "description", "status",
    "created", "updated",
    "research-refs", "supersedes", "superseded-by"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^AD-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["proposed", "accepted", "superseded", "deprecated"] },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "research-refs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^RES-\\d+$" }
    },
    "supersedes": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^AD-\\d+$" },
        { "type": "array", "items": { "type": "string", "pattern": "^AD-\\d+$" }, "minItems": 1 }
      ]
    },
    "superseded-by": { "type": ["string", "null"], "pattern": "^AD-\\d+$" }
  },
  "bodyTemplate": {
    "description": "Required body sections for decision artifacts",
    "sections": [
      { "heading": "Decision", "required": true },
      { "heading": "Rationale", "required": true },
      { "heading": "Consequences", "required": true }
    ]
  }
}
