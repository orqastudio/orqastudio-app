{
  "$id": "orqa://schemas/decision",
  "title": "Decision",
  "description": "Architecture decision record",
  "type": "object",
  "required": ["id", "title", "description", "status", "created", "updated", "relationships"],
  "additionalProperties": false,
  "propertyOrder": [
    "id", "title", "description", "status",
    "created", "updated",
    "layer", "research-refs", "supersedes", "superseded-by",
    "relationships"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^AD-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["proposed", "accepted", "superseded", "deprecated"] },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "layer": { "enum": ["core", "project", "plugin", "community", "user"] },
    "research-refs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^RES-\\d+$" }
    },
    "supersedes": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^AD-\\d+$" },
        { "type": "array", "items": { "type": "string", "pattern": "^AD-\\d+$" }, "minItems": 1 }
      ]
    },
    "superseded-by": { "type": ["string", "null"], "pattern": "^AD-\\d+$" },
    "relationships": {
      "type": "array",
      "description": "Pipeline connections. Decisions (Principle stage) should include 'practices' and 'enforces' relationships.",
      "items": {
        "type": "object",
        "required": ["type", "target", "rationale"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "enum": ["observes", "observed-by", "grounded", "grounded-by", "practices", "practiced-by", "enforces", "enforced-by", "verifies", "verified-by", "informs", "informed-by"]
          },
          "target": {
            "type": ["string", "null"],
            "pattern": "^(IMPL|AD|RULE|SKILL|PILLAR|RES|VER)-\\d+$"
          },
          "rationale": {
            "type": "string",
            "description": "Why this relationship exists"
          },
          "intended": {
            "type": "boolean",
            "description": "When target is null: true = human confirmed the gap is deliberate, any other value = unresolved tension"
          }
        }
      }
    }
  },
  "bodyTemplate": {
    "description": "Required body sections for decision artifacts",
    "sections": [
      { "heading": "Decision", "required": true },
      { "heading": "Rationale", "required": true },
      { "heading": "Consequences", "required": true }
    ]
  }
}
