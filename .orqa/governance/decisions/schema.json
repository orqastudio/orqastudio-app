{
  "$id": "orqa://schemas/decision",
  "title": "Decision",
  "description": "Architecture decision record",
  "type": "object",
  "required": ["id", "title", "description", "status", "created", "updated"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^AD-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["proposed", "accepted", "superseded", "deprecated"] },
    "category": { "type": "string", "description": "Decision category (e.g., architecture, persistence, governance)" },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "research-refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "supersedes": { "type": ["string", "null"] },
    "superseded-by": { "type": ["string", "null"] }
  },
  "bodyTemplate": {
    "description": "Required body sections for decision artifacts",
    "sections": [
      { "heading": "Decision", "required": true },
      { "heading": "Rationale", "required": true },
      { "heading": "Consequences", "required": true }
    ]
  }
}
