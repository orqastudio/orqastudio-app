{
  "$id": "orqa://schemas/task",
  "title": "Task",
  "description": "Individual implementation unit, optionally linked to an epic",
  "type": "object",
  "required": ["id", "title", "description", "status", "created", "updated"],
  "additionalProperties": false,
  "propertyOrder": [
    "id", "title", "description", "status",
    "created", "updated",
    "epic", "milestone", "horizon",
    "depends-on", "assignee", "docs", "skills",
    "acceptance", "rule-overrides"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^TASK-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["todo", "in-progress", "done"] },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "epic": { "type": ["string", "null"], "pattern": "^EPIC-\\d+$" },
    "milestone": { "type": ["string", "null"], "pattern": "^MS-\\d+$" },
    "horizon": { "enum": ["active", "next", "later", "someday", null] },
    "depends-on": {
      "type": "array",
      "items": { "type": "string", "pattern": "^TASK-\\d+$" }
    },
    "assignee": { "type": "string", "pattern": "^AGENT-\\d+$" },
    "docs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^DOC-\\d+$" },
      "description": "Documentation IDs (DOC-NNN) to load into agent context during implementation"
    },
    "skills": {
      "type": "array",
      "items": { "type": "string", "pattern": "^SKILL-\\d+$" },
      "description": "Skill IDs (SKILL-NNN) to load into agent context during implementation"
    },
    "acceptance": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rule-overrides": {
      "type": "array",
      "description": "Rules scoped-suspended for this task. Agents see the rule but know it is deliberately suspended with rationale.",
      "items": {
        "type": "object",
        "required": ["rule", "reason"],
        "additionalProperties": false,
        "properties": {
          "rule": { "type": "string", "pattern": "^RULE-\\d+$" },
          "reason": { "type": "string", "description": "Why this rule is suspended for this task" }
        }
      }
    }
  },
  "bodyTemplate": {
    "description": "Required body sections for task artifacts",
    "sections": [
      { "heading": "What", "required": true },
      { "heading": "How", "required": true },
      { "heading": "Verification", "required": true },
      { "heading": "Lessons", "required": true }
    ]
  }
}
