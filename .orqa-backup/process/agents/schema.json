{
  "$id": "orqa://schemas/agent",
  "title": "Agent",
  "description": "Universal agent role definition",
  "type": "object",
  "required": ["id", "title", "description", "status", "layer"],
  "additionalProperties": false,
  "propertyOrder": [
    "id", "title", "description", "status",
    "created", "updated",
    "layer", "model",
    "capabilities", "skills", "subagent_mapping"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^AGENT-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["captured", "exploring", "ready", "prioritised", "active", "hold", "blocked", "review", "completed", "surpassed", "recurring"] },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "layer": { "enum": ["orchestrator", "core", "project", "plugin", "community", "user"] },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Abstract capabilities resolved to provider-specific tools via RULE-040"
    },
    "skills": {
      "type": "array",
      "items": { "type": "string", "pattern": "^SKILL-\\d+$" }
    },
    "model": { "type": "string" },
    "subagent_mapping": { "type": "object" },
    "relationships": {
      "type": "array",
      "description": "Graph edges connecting this agent to other artifacts.",
      "items": {
        "type": "object",
        "required": ["type", "target", "rationale"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "enum": ["belongs-to", "contains", "delivers", "delivered-by", "observes", "observed-by", "grounded", "grounded-by", "practices", "practiced-by", "enforces", "enforced-by", "verifies", "verified-by", "informs", "informed-by", "scoped-to", "scoped-by", "documents", "documented-by"]
          },
          "target": {
            "type": ["string", "null"],
            "pattern": "^(IMPL|AD|RULE|SKILL|PILLAR|RES|VER|AGENT|DOC|EPIC|TASK|IDEA|MS)-\\d+$"
          },
          "rationale": {
            "type": "string",
            "description": "Why this relationship exists"
          },
          "intended": {
            "type": "boolean",
            "description": "When target is null: true = human confirmed the gap is deliberate, any other value = unresolved tension"
          }
        }
      }
    }
  }
}
