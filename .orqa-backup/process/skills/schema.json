{
  "$id": "orqa://schemas/skill",
  "title": "Skill",
  "description": "Domain knowledge or methodology loaded into agents",
  "type": "object",
  "required": ["id", "title", "description", "status", "layer", "category", "relationships"],
  "additionalProperties": false,
  "propertyOrder": [
    "id", "title", "description", "status",
    "created", "updated",
    "layer", "category", "file-patterns", "version",
    "user-invocable", "allowed-tools", "license", "metadata",
    "relationships"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^SKILL-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["active", "inactive"] },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "layer": { "enum": ["core", "setup", "project", "plugin", "community", "user"] },
    "file-patterns": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Glob patterns for file paths that trigger auto-injection of this skill"
    },
    "version": { "type": "string" },
    "user-invocable": { "type": "boolean" },
    "allowed-tools": { "type": "string" },
    "license": { "type": "string" },
    "metadata": { "type": "object" },
    "category": {
      "enum": ["methodology", "domain", "tool"],
      "description": "Skill category: methodology (grounded in Pillar), domain (grounded in Decision), tool (grounded in Decision)"
    },
    "relationships": {
      "type": "array",
      "description": "Pipeline connections. Skills (Practice stage) should include a 'grounded' relationship — to a Pillar for methodology, to a Decision for domain/tool.",
      "items": {
        "type": "object",
        "required": ["type", "target", "rationale"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "enum": ["belongs-to", "contains", "delivers", "delivered-by", "observes", "observed-by", "grounded", "grounded-by", "practices", "practiced-by", "enforces", "enforced-by", "verifies", "verified-by", "informs", "informed-by", "scoped-to", "scoped-by", "documents", "documented-by"]
          },
          "target": {
            "type": ["string", "null"],
            "pattern": "^(EPIC|TASK|MS|IMPL|AD|RULE|SKILL|PILLAR|RES|VER|IDEA|AGENT|DOC)-\\d+$"
          },
          "rationale": {
            "type": "string",
            "description": "Why this relationship exists"
          },
          "intended": {
            "type": "boolean",
            "description": "When target is null: true = human confirmed the gap is deliberate, any other value = unresolved tension"
          }
        }
      }
    }
  }
}
