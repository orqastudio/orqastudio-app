{
  "$id": "orqa://schemas/pillar",
  "title": "Pillar",
  "description": "Guiding principle that features are evaluated against",
  "type": "object",
  "required": ["id", "title", "description", "status", "created", "updated", "gate"],
  "additionalProperties": false,
  "propertyOrder": [
    "id", "title", "description", "status",
    "created", "updated",
    "gate"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^PILLAR-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["captured", "exploring", "ready", "prioritised", "active", "hold", "blocked", "review", "completed", "surpassed", "recurring"] },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "gate": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ],
      "description": "Gate question(s) to evaluate whether work serves this pillar"
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "target", "rationale"],
        "additionalProperties": false,
        "properties": {
          "type": { "type": "string" },
          "target": { "type": ["string", "null"], "pattern": "^(EPIC|TASK|MS|IMPL|AD|RULE|SKILL|PILLAR|RES|VER|IDEA|AGENT|DOC)-\\d+$" },
          "rationale": { "type": "string" },
          "intended": { "type": "boolean" }
        }
      },
      "description": "Bidirectional relationships to other artifacts in the knowledge maturity pipeline"
    }
  },
  "bodyTemplate": {
    "description": "Required body sections for pillar artifacts",
    "sections": [
      { "heading": "What This Pillar Means", "required": true },
      { "heading": "Examples of Work That Serves This Pillar", "required": true },
      { "heading": "Anti-Patterns", "required": true },
      { "heading": "Conflict Resolution", "required": true }
    ]
  }
}
