{
  "$id": "orqa://schemas/rule",
  "title": "Rule",
  "description": "Constraint that must be followed",
  "type": "object",
  "required": ["id", "title", "description", "status", "created", "updated", "layer", "relationships"],
  "additionalProperties": false,
  "propertyOrder": [
    "id", "title", "description", "status",
    "created", "updated",
    "layer", "enforcement",
    "relationships"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^RULE-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["captured", "exploring", "ready", "prioritised", "active", "hold", "blocked", "review", "completed", "surpassed", "recurring"] },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "layer": { "enum": ["core", "setup", "project", "plugin", "community", "user"] },
    "enforcement": {
      "type": "array",
      "description": "Machine-enforceable patterns evaluated by the companion plugin or app enforcement engine",
      "items": {
        "type": "object",
        "required": ["event", "action", "message"],
        "additionalProperties": false,
        "properties": {
          "event": { "enum": ["file", "bash", "prompt", "stop", "lint"] },
          "pattern": { "type": "string", "description": "Regex pattern (file/bash/prompt/stop) or linter rule name (lint)" },
          "paths": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Glob patterns to restrict which file paths this enforcement applies to"
          },
          "action": { "enum": ["block", "warn", "inject"] },
          "message": { "type": "string", "description": "Message shown when the pattern matches" },
          "skills": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Skill directory names to inject when action is 'inject'"
          }
        }
      }
    },
    "relationships": {
      "type": "array",
      "description": "Pipeline connections. Rules (Enforcement stage) must include at least one 'grounded' relationship.",
      "items": {
        "type": "object",
        "required": ["type", "target", "rationale"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "enum": ["belongs-to", "contains", "delivers", "delivered-by", "observes", "observed-by", "grounded", "grounded-by", "practices", "practiced-by", "enforces", "enforced-by", "verifies", "verified-by", "informs", "informed-by", "scoped-to", "scoped-by", "documents", "documented-by"]
          },
          "target": {
            "type": ["string", "null"],
            "pattern": "^(EPIC|TASK|MS|IMPL|AD|RULE|SKILL|PILLAR|RES|VER|IDEA|AGENT|DOC)-\\d+$"
          },
          "rationale": {
            "type": "string",
            "description": "Why this relationship exists"
          },
          "intended": {
            "type": "boolean",
            "description": "When target is null: true = human confirmed the gap is deliberate, any other value = unresolved tension"
          }
        }
      }
    }
  },
  "bodyTemplate": {
    "description": "Semi-structured body for rule artifacts. Opening paragraph and Related Rules required; FORBIDDEN encouraged.",
    "sections": [
      { "heading": "FORBIDDEN", "required": false },
      { "heading": "Related Rules", "required": true }
    ],
    "notes": "Rules must start with an opening paragraph stating the rule. Domain-specific sections vary by rule."
  }
}
