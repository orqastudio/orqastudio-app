{
  "$id": "orqa://schemas/lesson",
  "title": "Lesson",
  "description": "Learning capture — an observation or understood pattern from experience",
  "type": "object",
  "required": ["id", "title", "description", "status", "created", "updated", "recurrence", "maturity", "relationships"],
  "additionalProperties": false,
  "propertyOrder": [
    "id", "title", "description", "status",
    "created", "updated",
    "maturity", "recurrence", "relationships"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^IMPL-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["captured", "exploring", "ready", "prioritised", "active", "hold", "blocked", "review", "completed", "surpassed", "recurring"] },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "maturity": {
      "enum": ["observation", "understanding"],
      "description": "Pipeline stage: observation (raw capture) or understanding (root cause identified)"
    },
    "recurrence": { "type": "integer", "minimum": 0 },
    "relationships": {
      "type": "array",
      "description": "Pipeline connections. When maturity is 'understanding', must include at least one 'grounded' relationship.",
      "items": {
        "type": "object",
        "required": ["type", "target", "rationale"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "enum": ["belongs-to", "contains", "delivers", "delivered-by", "observes", "observed-by", "grounded", "grounded-by", "practices", "practiced-by", "enforces", "enforced-by", "verifies", "verified-by", "informs", "informed-by", "documents", "documented-by"]
          },
          "target": {
            "type": ["string", "null"],
            "pattern": "^(IMPL|AD|RULE|SKILL|PILLAR|RES|VER|IDEA|EPIC|TASK|MS|DOC|AGENT)-\\d+$"
          },
          "rationale": {
            "type": "string",
            "description": "Why this relationship exists"
          },
          "intended": {
            "type": "boolean",
            "description": "When target is null: true = human confirmed the gap is deliberate, any other value = unresolved tension"
          }
        }
      }
    }
  },
  "bodyTemplate": {
    "description": "Required body sections for lesson artifacts",
    "sections": [
      { "heading": "Pattern", "required": true },
      { "heading": "Fix", "required": true }
    ]
  }
}
