{
  "$id": "orqa://schemas/task",
  "title": "Task",
  "description": "Individual implementation unit, optionally linked to an epic",
  "type": "object",
  "required": ["id", "title", "description", "status", "created", "updated"],
  "additionalProperties": false,
  "propertyOrder": [
    "id", "title", "description", "status", "priority",
    "created", "updated",
    "epic", "milestone", "horizon",
    "depends-on", "assignee", "docs", "skills",
    "acceptance", "scoring", "rule-overrides", "relationships"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^TASK-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["captured", "exploring", "ready", "prioritised", "active", "hold", "blocked", "review", "completed", "surpassed", "recurring"] },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "epic": { "type": ["string", "null"], "pattern": "^EPIC-\\d+$" },
    "milestone": { "type": ["string", "null"], "pattern": "^MS-\\d+$" },
    "priority": { "enum": ["P1", "P2", "P3", null] },
    "horizon": { "enum": ["active", "next", "later", "someday", null] },
    "depends-on": {
      "type": "array",
      "items": { "type": "string", "pattern": "^TASK-\\d+$" }
    },
    "assignee": { "type": "string", "pattern": "^AGENT-\\d+$" },
    "docs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^DOC-\\d+$" },
      "description": "Documentation IDs (DOC-NNN) to load into agent context during implementation"
    },
    "skills": {
      "type": "array",
      "items": { "type": "string", "pattern": "^SKILL-\\d+$" },
      "description": "Skill IDs (SKILL-NNN) to load into agent context during implementation"
    },
    "acceptance": {
      "type": "array",
      "items": { "type": "string" }
    },
    "scoring": {
      "type": "object",
      "description": "Optional rationale for priority assessment. Freeform dimensions — projects choose their own.",
      "additionalProperties": { "type": "number" }
    },
    "rule-overrides": {
      "type": "array",
      "description": "Rules scoped-suspended for this task. Agents see the rule but know it is deliberately suspended with rationale.",
      "items": {
        "type": "object",
        "required": ["rule", "reason"],
        "additionalProperties": false,
        "properties": {
          "rule": { "type": "string", "pattern": "^RULE-\\d+$" },
          "reason": { "type": "string", "description": "Why this rule is suspended for this task" }
        }
      }
    },
    "relationships": {
      "type": "array",
      "description": "Semantic graph edges connecting this task to other artifacts.",
      "items": {
        "type": "object",
        "required": ["type", "target"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "enum": ["belongs-to", "contains", "delivers", "delivered-by", "observes", "observed-by", "grounded", "grounded-by", "practices", "practiced-by", "enforces", "enforced-by", "verifies", "verified-by", "informs", "informed-by", "documents", "documented-by"]
          },
          "target": {
            "type": ["string", "null"],
            "pattern": "^(EPIC|TASK|MS|IMPL|AD|RULE|SKILL|PILLAR|RES|VER|IDEA|AGENT)-\\d+$"
          },
          "rationale": {
            "type": "string",
            "description": "Why this relationship exists"
          },
          "intended": {
            "type": "boolean",
            "description": "When target is null: true = human confirmed the gap is deliberate"
          }
        }
      }
    }
  },
  "bodyTemplate": {
    "description": "Required body sections for task artifacts",
    "sections": [
      { "heading": "What", "required": true },
      { "heading": "How", "required": true },
      { "heading": "Verification", "required": true },
      { "heading": "Lessons", "required": true }
    ]
  }
}
