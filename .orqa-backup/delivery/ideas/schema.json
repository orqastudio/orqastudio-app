{
  "$id": "orqa://schemas/idea",
  "title": "Idea",
  "description": "Candidate for future work, needs validation",
  "type": "object",
  "required": ["id", "title", "description", "status", "created", "updated", "pillars"],
  "additionalProperties": false,
  "propertyOrder": [
    "id", "title", "description", "status",
    "created", "updated",
    "pillars", "milestone", "horizon", "research-needed", "promoted-to", "spun-off-from", "relationships"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^IDEA-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["captured", "exploring", "ready", "prioritised", "active", "hold", "blocked", "review", "completed", "surpassed", "recurring"] },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "pillars": {
      "type": "array",
      "items": { "type": "string", "pattern": "^PILLAR-\\d+$" }
    },
    "milestone": { "type": ["string", "null"], "pattern": "^MS-\\d+$" },
    "horizon": { "enum": ["active", "next", "later", "someday", null] },
    "research-needed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "promoted-to": { "type": ["string", "null"], "pattern": "^EPIC-\\d+$" },
    "spun-off-from": { "type": ["string", "null"], "pattern": "^IDEA-\\d+$" },
    "relationships": {
      "type": "array",
      "description": "Semantic graph edges connecting this idea to other artifacts.",
      "items": {
        "type": "object",
        "required": ["type", "target"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "enum": ["belongs-to", "contains", "delivers", "delivered-by", "observes", "observed-by", "grounded", "grounded-by", "practices", "practiced-by", "enforces", "enforced-by", "verifies", "verified-by", "informs", "informed-by", "documents", "documented-by"]
          },
          "target": {
            "type": ["string", "null"],
            "pattern": "^(EPIC|TASK|MS|IMPL|AD|RULE|SKILL|PILLAR|RES|VER|IDEA|AGENT|DOC)-\\d+$"
          },
          "rationale": {
            "type": "string",
            "description": "Why this relationship exists"
          },
          "intended": {
            "type": "boolean",
            "description": "When target is null: true = human confirmed the gap is deliberate"
          }
        }
      }
    }
  },
  "bodyTemplate": {
    "description": "Required body sections for idea artifacts",
    "sections": [
      { "heading": "Motivation", "required": true },
      { "heading": "Sketch", "required": false }
    ]
  }
}
