{
  "$id": "orqa://schemas/epic",
  "title": "Epic",
  "description": "Trackable work unit within a milestone",
  "type": "object",
  "required": [
    "id", "title", "description", "status", "priority",
    "created", "updated", "pillars"
  ],
  "additionalProperties": false,
  "propertyOrder": [
    "id", "title", "description", "status", "priority",
    "created", "updated", "deadline",
    "milestone", "horizon", "pillars",
    "depends-on", "blocks", "research-refs",
    "docs-required", "docs-produced", "scoring",
    "rule-overrides", "relationships"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^EPIC-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["captured", "exploring", "ready", "prioritised", "active", "hold", "blocked", "review", "completed", "surpassed", "recurring"] },
    "priority": { "enum": ["P1", "P2", "P3"] },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "deadline": { "type": ["string", "null"], "format": "date" },
    "milestone": { "type": ["string", "null"], "pattern": "^MS-\\d+$" },
    "horizon": { "enum": ["active", "next", "later", "someday", null] },
    "pillars": {
      "type": "array",
      "items": { "type": "string", "pattern": "^PILLAR-\\d+$" }
    },
    "depends-on": {
      "type": "array",
      "items": { "type": "string", "pattern": "^EPIC-\\d+$" }
    },
    "blocks": {
      "type": "array",
      "items": { "type": "string", "pattern": "^EPIC-\\d+$" }
    },
    "research-refs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^RES-\\d+$" }
    },
    "docs-required": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Z]+-\\d+$" }
    },
    "docs-produced": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Z]+-\\d+$" }
    },
    "scoring": {
      "type": "object",
      "description": "Optional rationale for priority assessment. Freeform dimensions — projects choose their own. See DOC-062 for assessment criteria.",
      "additionalProperties": { "type": "number" }
    },
    "rule-overrides": {
      "type": "array",
      "description": "Rules scoped-suspended for this epic. Inherited by tasks that have no rule-overrides of their own. Tasks with their own rule-overrides replace this list entirely.",
      "items": {
        "type": "object",
        "required": ["rule", "reason"],
        "additionalProperties": false,
        "properties": {
          "rule": { "type": "string", "pattern": "^RULE-\\d+$" },
          "reason": { "type": "string", "description": "Why this rule is suspended for this epic" }
        }
      }
    },
    "relationships": {
      "type": "array",
      "description": "Semantic graph edges connecting this epic to other artifacts.",
      "items": {
        "type": "object",
        "required": ["type", "target"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "enum": ["belongs-to", "contains", "delivers", "delivered-by", "observes", "observed-by", "grounded", "grounded-by", "practices", "practiced-by", "enforces", "enforced-by", "verifies", "verified-by", "informs", "informed-by", "documents", "documented-by"]
          },
          "target": {
            "type": ["string", "null"],
            "pattern": "^(EPIC|TASK|MS|IMPL|AD|RULE|SKILL|PILLAR|RES|VER|IDEA|AGENT)-\\d+$"
          },
          "rationale": {
            "type": "string",
            "description": "Why this relationship exists"
          },
          "intended": {
            "type": "boolean",
            "description": "When target is null: true = human confirmed the gap is deliberate"
          }
        }
      }
    }
  },
  "bodyTemplate": {
    "description": "Required body sections for epic artifacts",
    "sections": [
      { "heading": "Context", "required": true },
      { "heading": "Implementation Design", "required": true },
      { "heading": "Tasks", "required": true },
      { "heading": "Out of Scope", "required": false }
    ]
  }
}
