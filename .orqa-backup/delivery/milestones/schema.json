{
  "$id": "orqa://schemas/milestone",
  "title": "Milestone",
  "description": "Strategic goal with gate question",
  "type": "object",
  "required": ["id", "title", "description", "status", "created", "updated", "gate"],
  "additionalProperties": false,
  "propertyOrder": [
    "id", "title", "description", "status",
    "created", "updated", "deadline",
    "gate", "relationships"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^MS-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["captured", "exploring", "ready", "prioritised", "active", "hold", "blocked", "review", "completed", "surpassed", "recurring"] },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "deadline": { "type": ["string", "null"], "format": "date" },
    "gate": { "type": "string" },
    "relationships": {
      "type": "array",
      "description": "Semantic graph edges connecting this milestone to other artifacts.",
      "items": {
        "type": "object",
        "required": ["type", "target"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "enum": ["belongs-to", "contains", "delivers", "delivered-by", "observes", "observed-by", "grounded", "grounded-by", "practices", "practiced-by", "enforces", "enforced-by", "verifies", "verified-by", "informs", "informed-by", "documents", "documented-by"]
          },
          "target": {
            "type": ["string", "null"],
            "pattern": "^(EPIC|TASK|MS|IMPL|AD|RULE|SKILL|PILLAR|RES|VER|IDEA|AGENT|DOC)-\\d+$"
          },
          "rationale": {
            "type": "string",
            "description": "Why this relationship exists"
          },
          "intended": {
            "type": "boolean",
            "description": "When target is null: true = human confirmed the gap is deliberate"
          }
        }
      }
    }
  },
  "bodyTemplate": {
    "description": "Required body sections for milestone artifacts",
    "sections": [
      { "heading": "Context", "required": true },
      { "heading": "Epics", "required": true },
      { "heading": "Completion Criteria", "required": false }
    ]
  }
}
