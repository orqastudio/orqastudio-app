{
  "$id": "orqa://schemas/research",
  "title": "Research",
  "description": "Investigation, design exploration, or implementation plan",
  "type": "object",
  "required": ["id", "title", "description", "status", "created", "updated"],
  "additionalProperties": false,
  "propertyOrder": [
    "id", "title", "description", "status",
    "created", "updated",
    "surpassed-by", "sources", "relationships"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^RES-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["captured", "exploring", "ready", "prioritised", "active", "hold", "blocked", "review", "completed", "surpassed", "recurring"] },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "surpassed-by": { "type": ["string", "null"], "pattern": "^RES-\\d+$" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url", "description"],
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "description": { "type": "string" },
          "tier": {
            "enum": ["T1", "T2", "T3", "T4"],
            "description": "Credibility tier: T1=Authoritative, T2=Established, T3=Community, T4=Unverified"
          }
        },
        "additionalProperties": false
      },
      "description": "External sources that informed this research"
    }
  },
    "relationships": {
      "type": "array",
      "description": "Cross-references to other artifacts in the knowledge graph",
      "items": {
        "type": "object",
        "required": ["type", "target", "rationale"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "enum": ["belongs-to", "contains", "delivers", "delivered-by", "observes", "observed-by", "grounded", "grounded-by", "practices", "practiced-by", "enforces", "enforced-by", "verifies", "verified-by", "informs", "informed-by", "documents", "documented-by"]
          },
          "target": {
            "type": ["string", "null"],
            "pattern": "^(IMPL|AD|RULE|SKILL|PILLAR|RES|VER|EPIC|TASK|IDEA|MS|DOC|AGENT)-\\d+$"
          },
          "rationale": {
            "type": "string"
          }
        }
      }
    }
  },
  "bodyTemplate": null
}
